                  ${interaction.level.toUpperCase()} RISK
                </span>
              </h4>
              <p style="margin:5px 0;"><strong>Mechanism:</strong> ${interaction.mechanism}</p>
              <p style="margin:5px 0;">${interaction.message}</p>
              <p style="margin:10px 0 0 0; padding:8px; background:rgba(255,255,255,0.5); border-radius:4px;">
                <strong>Recommendation:</strong> ${interaction.recommendation}
              </p>
            </div>
          `;
        });
        
        // Add general safety note
        resultsHTML += `
          <div style="margin-top:20px; padding:15px; background:#e3f2fd; border-radius:8px; border-left:4px solid #2196f3;">
            <h5 style="margin:0 0 10px 0; color:#1976d2;"><i class="fas fa-shield-alt"></i> Clinical Safety Note</h5>
