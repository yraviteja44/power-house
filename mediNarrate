    // Validate medications against known database
    function validateMedications(drugs) {
      const known = [];
      const unknown = [];
      
      drugs.forEach(drug => {
        let found = false;
        
        // Check if drug matches any known medication or its aliases
        for (const [key, medication] of Object.entries(drugDatabase.validMedications)) {
          if (medication.names.includes(drug)) {
            known.push(key);
            found = true;
            break;
          }
        }
        
        // Also check direct key match
        if (!found && drugDatabase.validMedications[drug]) {
          known.push(drug);
          found = true;
        }
        
        if (!found) {
          unknown.push(drug);
        }
      });
      
      return { known, unknown };
    }

    // Find interactions between validated medications
    function findDrugInteractions(validatedDrugs) {
      const interactionsFound = [];
      
      // Check all possible combinations
      for (let i = 0; i < validatedDrugs.length; i++) {
        for (let j = i + 1; j < validatedDrugs.length; j++) {
          const drugA = validatedDrugs[i];
          const drugB = validatedDrugs[j];
          
          // Check both directions
          if (drugDatabase.interactions[drugA] && drugDatabase.interactions[drugA][drugB]) {
            interactionsFound.push({
              drugs: [drugA, drugB],
              ...drugDatabase.interactions[drugA][drugB]
            });
          } else if (drugDatabase.interactions[drugB] && drugDatabase.interactions[drugB][drugA]) {
            interactionsFound.push({
              drugs: [drugB, drugA],
              ...drugDatabase.interactions[drugB][drugA]
            });
          }
        }
      }
      
      return interactionsFound;
    }

    // Auto-suggest medications as user types
    function setupDrugSuggestions() {
      const drugInputs = ['drug1', 'drug2', 'drug3'];
      
      drugInputs.forEach(inputId => {
        const input = document.getElementById(inputId);
        if (input) {
          input.addEventListener('input', function() {
            showDrugSuggestions(this);
          });
          
          input.addEventListener('focus', function() {
            showDrugSuggestions(this);
          });
          
          input.addEventListener('blur', function() {
            setTimeout(() => {
              hideDrugSuggestions(this);
            }, 200);
          });
        }
      });
    }

    function showDrugSuggestions(input) {
      const value = input.value.toLowerCase();
      if (value.length < 2) return;
      
      const suggestions = [];
      
      // Find matching medications
      for (const [key, medication] of Object.entries(drugDatabase.validMedications)) {
        if (medication.names.some(name => name.includes(value)) || key.includes(value)) {
          suggestions.push({
            name: key,
            aliases: medication.names.slice(0, 2)
          });
        }
      }
      
      if (suggestions.length > 0) {
        let suggestionsHTML = '<div class="drug-suggestions">';
        suggestions.forEach(suggestion => {
          suggestionsHTML += `
            <div class="suggestion-item" onclick="selectSuggestion(this, '${suggestion.name}')">
              <strong>${suggestion.name}</strong>
              <small>${suggestion.aliases.join(', ')}</small>
            </div>
          `;
        });
        suggestionsHTML += '</div>';
        
        // Remove existing suggestions
        const existingSuggestions = input.parentNode.querySelector('.drug-suggestions');
        if (existingSuggestions) {
          existingSuggestions.remove();
        }
        
        input.parentNode.insertAdjacentHTML('beforeend', suggestionsHTML);
      }
    }

    function hideDrugSuggestions(input) {
      const suggestions = input.parentNode.querySelector('.drug-suggestions');
      if (suggestions) {
        suggestions.remove();
      }
    }

    function selectSuggestion(element, drugName) {
      const input = element.closest('.drug-input-group').querySelector('.drug-input');
      input.value = drugName;
      hideDrugSuggestions(input);
    }

