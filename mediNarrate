    function extractDetailedVitals(note) {
      const vitals = {};
      
      const bpMatch = note.match(/(\d+)\s*\/\s*(\d+)\s*(?:mmhg|bp|blood pressure)/i);
      if (bpMatch) vitals.bp = `${bpMatch[1]}/${bpMatch[2]} mmHg`;
      
