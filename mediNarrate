      if (tempMatch) vitals.temp = `${tempMatch[1]}°F`;
      
      const hrMatch = note.match(/(\d+)\s*(?:bpm|hr|heart rate)/i);
      if (hrMatch) vitals.hr = `${hrMatch[1]} bpm`;
      
      return Object.keys(vitals).length > 0 ? vitals : { note: 'Vital signs not documented' };
    }

