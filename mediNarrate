        return;
      }
      
      const drugs = [drug1, drug2];
      if (drug3) drugs.push(drug3);
      
      // Validate medications first
      const validatedDrugs = validateMedications(drugs);
      const unknownDrugs = validatedDrugs.unknown;
      const knownDrugs = validatedDrugs.known;
      
      let resultsHTML = '';
      
      // Show unknown medications warning
      if (unknownDrugs.length > 0) {
        resultsHTML += `
          <div class="interaction-medium">
            <h4><i class="fas fa-exclamation-triangle"></i> Unknown Medications</h4>
            <p>The following medications were not recognized: <strong>${unknownDrugs.join(', ')}</strong></p>
            <p style="font-size:0.9em; margin-top:8px;">
              <i class="fas fa-lightbulb"></i> Please check spelling or use generic names. Only known medications can be checked for interactions.
            </p>
          </div>
        `;
      }
      
      // If no known medications, show error
      if (knownDrugs.length < 2) {
        resultsHTML += `
          <div class="interaction-high">
            <h4><i class="fas fa-times-circle"></i> Insufficient Data</h4>
            <p>Need at least 2 recognized medications to check for interactions.</p>
            <p>Try using generic names like "ibuprofen" instead of brand names.</p>
          </div>
        `;
        resultsDiv.innerHTML = resultsHTML;
        return;
      }
      
      // Check interactions between known medications
      const interactionsFound = findDrugInteractions(knownDrugs);
      
      if (interactionsFound.length === 0) {
        resultsHTML += `
          <div style="text-align:center; color:#28a745; padding:20px;">
            <i class="fas fa-check-circle" style="font-size:2rem; margin-bottom:10px;"></i>
            <h3>No Significant Interactions Found</h3>
            <p>No major drug interactions detected between the recognized medications:</p>
            <p><strong>${knownDrugs.join(', ')}</strong></p>
            <div style="margin-top:15px; padding:10px; background:#e8f5e8; border-radius:5px;">
              <small><i class="fas fa-info-circle"></i> Always monitor patients for unexpected side effects.</small>
            </div>
          </div>
        `;
      } else {
        resultsHTML += '<h3 style="color:#333; margin-bottom:15px;"><i class="fas fa-exclamation-triangle"></i> Drug Interaction Results</h3>';
        
        interactionsFound.forEach(interaction => {
          const levelClass = `interaction-${interaction.level}`;
          resultsHTML += `
            <div class="${levelClass}">
              <h4 style="margin:0 0 10px 0; display:flex; align-items:center; gap:8px;">
                <i class="fas fa-capsules"></i>
